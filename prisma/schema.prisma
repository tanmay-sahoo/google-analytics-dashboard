generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum DataSourceType {
  GA4
  ADS
  MERCHANT
}

enum MetricSource {
  GA4
  ADS
}

enum AlertCondition {
  GT
  LT
  PCT_CHANGE
}

enum AlertScope {
  PROJECT
  CAMPAIGN
}

enum AlertWindowUnit {
  MINUTES
  HOURS
  DAYS
  WEEKS
  MONTHS
}

enum AlertAggregation {
  LATEST
  SUM
  AVG
}

enum AlertStatus {
  TRIGGERED
  DELIVERED
  MUTED
}

enum NotificationKind {
  ALERT
  SYSTEM
}

enum IngestionStatus {
  STARTED
  COMPLETED
  FAILED
}

model User {
  id           String       @id @default(cuid())
  name         String?
  email        String       @unique
  passwordHash String
  role         Role         @default(USER)
  isActive     Boolean      @default(true)
  menuAccess   Json?
  locale       String       @default("en")
  theme        String       @default("light")
  createdById  String?
  createdAt    DateTime     @default(now())
  projectUsers ProjectUser[]
  createdRules AlertRule[]  @relation("CreatedRules")
  activityLogs ActivityLog[]
  notifications Notification[] @relation("UserNotifications")

  createdBy    User?        @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers User[]       @relation("UserCreator")
}

model Project {
  id            String             @id @default(cuid())
  name          String
  timezone      String
  currency      String
  createdAt     DateTime           @default(now())
  projectUsers  ProjectUser[]
  dataSources   DataSourceAccount[]
  metrics       MetricDaily[]
  reportCaches  ReportCache[]
  ingestionLogs IngestionProjectLog[]
  merchantProducts MerchantProduct[]
  alertRules    AlertRule[]
  alertEvents   AlertEvent[]
  notifications Notification[] @relation("ProjectNotifications")
}

model ProjectUser {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model DataSourceAccount {
  id             String         @id @default(cuid())
  projectId      String
  type           DataSourceType
  externalId     String
  createdAt      DateTime       @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type])
}

model IntegrationSetting {
  id             String         @id @default(cuid())
  type           DataSourceType @unique
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  connectedEmail String?
  createdAt      DateTime       @default(now())
}

model MetricDaily {
  id        String       @id @default(cuid())
  projectId String
  date      DateTime
  source    MetricSource
  metrics   Json
  createdAt DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, date, source])
}

model ReportCache {
  id         String   @id @default(cuid())
  projectId  String
  reportKey  String
  rangeStart DateTime
  rangeEnd   DateTime
  data       Json
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, reportKey, rangeStart, rangeEnd])
}

model IngestionSetting {
  id           String   @id @default(cuid())
  key          String   @unique
  enabled      Boolean  @default(false)
  intervalMins Int      @default(1440)
  lastRunAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  message    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model IngestionRun {
  id            String          @id @default(cuid())
  status        IngestionStatus @default(STARTED)
  startedAt     DateTime        @default(now())
  finishedAt    DateTime?
  totalProjects Int             @default(0)
  totalGa4      Int             @default(0)
  totalAds      Int             @default(0)
  error         String?
  projectLogs   IngestionProjectLog[]
}

model IngestionProjectLog {
  id         String   @id @default(cuid())
  runId      String
  projectId  String
  ga4Inserted Int     @default(0)
  adsInserted Int     @default(0)
  error      String?
  startedAt  DateTime @default(now())
  finishedAt DateTime?

  run     IngestionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model MerchantProduct {
  id            String   @id @default(cuid())
  projectId     String
  merchantId    String
  offerId       String
  title         String
  link          String?
  imageLink     String?
  availability  String?
  priceValue    Float?
  priceCurrency String?
  clicks        Int      @default(0)
  impressions   Int      @default(0)
  sales         Int      @default(0)
  revenue       Float    @default(0)
  performanceAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, merchantId, offerId])
}

model MerchantAccountImport {
  id         String   @id @default(cuid())
  merchantId String   @unique
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SmtpSetting {
  id        String   @id @default(cuid())
  key       String   @unique @default("default")
  host      String
  port      Int
  secure    Boolean  @default(true)
  username  String
  password  String
  fromEmail String
  fromName  String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiConfig {
  id        String   @id @default(cuid())
  provider  String
  model     String
  apiKey    String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AlertRule {
  id               String          @id @default(cuid())
  projectId        String
  createdByUserId  String
  metric           String
  scope            AlertScope
  filter           Json?
  condition        AlertCondition
  threshold        Float
  windowAmount     Int             @default(1)
  windowUnit       AlertWindowUnit @default(DAYS)
  aggregation      AlertAggregation @default(LATEST)
  evaluateEveryMins Int            @default(60)
  channels         Json
  cooldownMins     Int
  enabled          Boolean         @default(true)
  lastEvaluatedAt  DateTime?
  createdAt        DateTime        @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User  @relation("CreatedRules", fields: [createdByUserId], references: [id], onDelete: Cascade)
  events   AlertEvent[]
}

model AlertEvent {
  id          String      @id @default(cuid())
  ruleId      String
  projectId   String
  evaluatedAt DateTime
  value       Float
  message     String
  status      AlertStatus
  deliveredAt DateTime?

  rule    AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  notifications Notification[]
}

model Notification {
  id           String           @id @default(cuid())
  userId       String
  projectId    String?
  alertEventId String?
  kind         NotificationKind @default(ALERT)
  title        String
  body         String
  href         String?
  readAt       DateTime?
  createdAt    DateTime         @default(now())

  user       User        @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  project    Project?    @relation("ProjectNotifications", fields: [projectId], references: [id], onDelete: SetNull)
  alertEvent AlertEvent? @relation(fields: [alertEventId], references: [id], onDelete: SetNull)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model BrandSetting {
  key       String   @id @default("default")
  logoData  String?  // base64 data URI ("data:image/png;base64,...")
  updatedAt DateTime @updatedAt
}

model ReportSnapshot {
  id         String   @id @default(cuid())
  source     String   // "ga4" | "ads"
  externalId String   // GA4 propertyId or Ads customerId
  reportType String   // e.g. "ga4-project-reports", "ga4-ecommerce", "ads-intelligence"
  rangeKey   String   // canonical key including dates and any extra params (dimension, metric, ...)
  startDate  DateTime
  endDate    DateTime
  data       Json
  fetchedAt  DateTime @default(now())

  @@unique([source, externalId, reportType, rangeKey])
  @@index([source, externalId, reportType])
  @@index([fetchedAt])
}
