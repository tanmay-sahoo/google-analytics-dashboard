DATABASE_URL="postgres://"
NEXTAUTH_URL="http://localhost:3002"
NEXTAUTH_SECRET="replace-with-a-strong-secret"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3002/api/integrations/google/callback"
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_MANAGER_CUSTOMER_ID="" # Optional. Leave empty if OAuth has direct access (non-MCC).
GOOGLE_ADS_API_VERSION="v20"
CRON_SECRET=""
APP_BASE_URL="http://localhost:3002"
DATA_ENCRYPTION_KEY=""

# --- Used only by docker-compose.yml when bringing up the bundled Postgres ---
POSTGRES_DB="marketing_data_hub"
POSTGRES_USER="app"
POSTGRES_PASSWORD="changeme"
